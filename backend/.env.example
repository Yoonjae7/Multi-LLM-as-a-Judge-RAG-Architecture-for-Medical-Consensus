# OpenAI-compatible provider configuration. LLM_API_KEY is optional.
# The API continues to work in deterministic mock mode when it is blank.
LLM_PROVIDER=siliconflow
LLM_API_KEY=
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_TIMEOUT_SECONDS=45
LLM_MAX_TOKENS=900

# Reserved for the next hybrid-retrieval iteration. The MVP uses local keyword retrieval.
EMBEDDING_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
